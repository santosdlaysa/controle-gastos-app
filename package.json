{
  "name": "orgenyx",
  "version": "2.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:server\" \"pnpm dev:metro\"",
    "dev:android": "concurrently -k \"pnpm dev:server\" \"pnpm dev:metro:android\"",
    "dev:server": "cross-env NODE_ENV=development tsx watch server/_core/index.ts",
    "dev:metro": "cross-env EXPO_USE_METRO_WORKSPACE_ROOT=1 EXPO_ROUTER_DISABLE_RN_NAVIGATION_CHECK=1 npx expo start --web --port 8081",
    "dev:metro:android": "cross-env EXPO_USE_METRO_WORKSPACE_ROOT=1 EXPO_ROUTER_DISABLE_RN_NAVIGATION_CHECK=1 npx expo start --android --port 8081",
    "build": "esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outfile=dist/index.mjs",
    "start": "NODE_ENV=production node dist/index.mjs",
    "web": "expo start --web",
    "check": "tsc --noEmit",
    "lint": "expo lint",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:push": "node scripts/db-push.mjs",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "qr": "node scripts/generate_qr.mjs"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.8.12",
    "@react-navigation/elements": "^2.9.2",
    "@react-navigation/native": "^7.1.25",
    "@tanstack/react-query": "^5.90.12",
    "@trpc/client": "11.7.2",
    "@trpc/react-query": "11.7.2",
    "@trpc/server": "11.7.2",
    "axios": "^1.13.2",
    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.7",
    "expo": "^56.0.0",
    "expo-audio": "~56.0.11",
    "expo-build-properties": "^56.0.16",
    "expo-constants": "~56.0.16",
    "expo-font": "~56.0.5",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.9",
    "expo-keep-awake": "~56.0.3",
    "expo-linking": "~56.0.13",
    "expo-notifications": "~56.0.15",
    "expo-router": "~56.2.8",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.5",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.17",
    "expo-video": "~56.1.2",
    "expo-web-browser": "~56.0.5",
    "express": "^4.22.1",
    "jose": "6.1.0",
    "mysql2": "^3.16.0",
    "nativewind": "^4.2.1",
    "openai": "^6.25.0",
    "postgres": "^3.4.8",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.2",
    "react-native-google-mobile-ads": "^16.3.3",
    "react-native-pluggy-connect": "^1.4.1",
    "react-native-purchases": "^10.0.1",
    "react-native-purchases-ui": "^10.0.1",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.2",
    "react-native-webview": "^13.16.0",
    "react-native-worklets": "0.8.3",
    "resend": "^6.9.3",
    "superjson": "^1.13.3",
    "tailwind-merge": "^2.6.0",
    "yaml": "2.8.2",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/cookie": "^0.6.0",
    "@types/express": "^4.17.25",
    "@types/node": "^22.19.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "~19.2.15",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "drizzle-kit": "^0.31.8",
    "esbuild": "0.27.3",
    "eslint": "^9.39.2",
    "eslint-config-expo": "~56.0.4",
    "metro-minify-terser": "^0.84.4",
    "prettier": "^3.7.4",
    "qrcode": "^1.5.4",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@9.12.0",
  "pnpm": {
    "overrides": {
      "esbuild": "0.27.3",
      "ws": "^8.18.0"
    }
  }
}
